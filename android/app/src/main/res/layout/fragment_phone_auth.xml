<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvPhoneTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/phone_auth_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <RadioGroup
            android:id="@+id/rgPhoneMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbPhoneRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_register" />

            <RadioButton
                android:id="@+id/rbPhonePasswordLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_password_login" />

            <RadioButton
                android:id="@+id/rbPhoneCodeLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_code_login" />

            <RadioButton
                android:id="@+id/rbPhoneReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_reset_password" />
        </RadioGroup>

        <EditText
            android:id="@+id/etPhoneCountryCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/country_code"
            android:inputType="number" />

        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/phone_number"
            android:inputType="phone" />

        <EditText
            android:id="@+id/etPhonePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/password"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/etPhoneCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/verify_code"
            android:inputType="number" />

        <Button
            android:id="@+id/btnPhoneSendCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/send_code" />

        <Button
            android:id="@+id/btnPhoneSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/submit" />

        <Button
            android:id="@+id/btnPhoneBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/back" />

        <ProgressBar
            android:id="@+id/progressPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:visibility="gone" />
    </LinearLayout>

</ScrollView>
