<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/convert_account_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <RadioGroup
            android:id="@+id/rgConvertMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbConvertPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/convert_mode_phone" />

            <RadioButton
                android:id="@+id/rbConvertEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/convert_mode_email" />
        </RadioGroup>

        <EditText
            android:id="@+id/etConvertCountryCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/country_code"
            android:inputType="number" />

        <EditText
            android:id="@+id/etConvertUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/convert_target_account" />

        <EditText
            android:id="@+id/etConvertCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/verify_code"
            android:inputType="number" />

        <EditText
            android:id="@+id/etConvertPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/convert_password_hint"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnConvertSendCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/send_code" />

        <Button
            android:id="@+id/btnConvertSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/submit" />

        <Button
            android:id="@+id/btnConvertBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/back" />

        <ProgressBar
            android:id="@+id/progressConvert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:visibility="gone" />
    </LinearLayout>

</ScrollView>
