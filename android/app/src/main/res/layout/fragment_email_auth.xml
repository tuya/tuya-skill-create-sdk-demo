<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvEmailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_auth_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <RadioGroup
            android:id="@+id/rgEmailMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbEmailRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_register" />

            <RadioButton
                android:id="@+id/rbEmailPasswordLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_password_login" />

            <RadioButton
                android:id="@+id/rbEmailCodeLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_code_login" />

            <RadioButton
                android:id="@+id/rbEmailReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_reset_password" />
        </RadioGroup>

        <EditText
            android:id="@+id/etEmailCountryCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/country_code"
            android:inputType="number" />

        <EditText
            android:id="@+id/etEmailAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/email_address"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/etEmailPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/password"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/etEmailCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/verify_code"
            android:inputType="number" />

        <Button
            android:id="@+id/btnEmailSendCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/send_code" />

        <Button
            android:id="@+id/btnEmailSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/submit" />

        <Button
            android:id="@+id/btnEmailBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/back" />

        <ProgressBar
            android:id="@+id/progressEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:visibility="gone" />
    </LinearLayout>

</ScrollView>
